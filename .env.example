# Provider: anthropic | openai | zai
LLM_PROVIDER=anthropic

# Z.AI — https://docs.z.ai/ (Open Platform → API Keys)
ZAI_API_KEY=
ZAI_MODEL=glm-4.7-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Read-aloud voice: edge (free neural, default) | openai (needs OPENAI_API_KEY)
TTS_PROVIDER=edge
OPENAI_TTS_VOICE=nova

# Server port (default 3001)
PORT=3001

# NHS email — users connect their own inbox in Account settings.
# Optional server-wide fallback (normally leave blank):
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_USER=you@example.com
# EMAIL_PASSWORD=your-app-password
EMAIL_SUBJECT_FILTER=NHSINFORMATION
