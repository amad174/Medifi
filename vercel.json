{
  "installCommand": "cd server && npm install",
  "buildCommand": "node scripts/write-firebase-config.js",
  "redirects": [
    {
      "source": "/",
      "destination": "/ui_kits/app/index.html",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api", "destination": "/api" },
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/**"
    }
  }
}
