{
  "version": 2,
  "installCommand": "npm install && cd server && npm install",
  "buildCommand": "node scripts/write-firebase-config.js",
  "builds": [
    {
      "src": "api/[...path].js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/**"]
      }
    },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "favicon.png", "use": "@vercel/static" },
    { "src": "ui_kits/**", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "tokens/**", "use": "@vercel/static" },
    { "src": "_ds_bundle.js", "use": "@vercel/static" },
    { "src": "_ds_fallback.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "api/[...path].js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
