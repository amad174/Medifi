{
  "installCommand": "npm install && cd server && npm install",
  "buildCommand": "node scripts/write-firebase-config.js",
  "redirects": [
    {
      "source": "/",
      "destination": "/ui_kits/app/index.html",
      "permanent": false
    }
  ],
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/**"
    }
  }
}
